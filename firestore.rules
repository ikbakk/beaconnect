rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function pairDoc(pairId) {
      return get(/databases/$(database)/documents/pairs/$(pairId));
    }

    function isPairMember(pairId) {
      return isSignedIn()
        && pairDoc(pairId).data.memberIds is list
        && request.auth.uid in pairDoc(pairId).data.memberIds;
    }

    match /users/{userId} {
      allow read, write: if isSelf(userId);
    }

    match /pairs/{pairId} {
      allow read: if isPairMember(pairId);
      allow create: if isSignedIn()
        && request.resource.data.memberIds is list
        && request.auth.uid in request.resource.data.memberIds;
      allow update: if isPairMember(pairId);
      allow delete: if false;
    }

    match /pairs/{pairId}/events/{eventId} {
      allow read, create: if isPairMember(pairId);
      allow update, delete: if false;
    }

    match /pairs/{pairId}/liveSessions/{sessionId} {
      allow read, create, update: if isPairMember(pairId);
      allow delete: if false;
    }

    match /inviteCodes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isSignedIn()
        && (
          resource.data.createdBy == request.auth.uid
          || request.resource.data.usedBy == request.auth.uid
        );
      allow delete: if false;
    }

    match /devices/{deviceId} {
      allow read, write: if isSignedIn();
    }
  }
}
