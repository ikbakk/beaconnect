rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function pairDoc(pairId) {
      return get(/databases/$(database)/documents/pairs/$(pairId));
    }

    function inviteDoc(code) {
      return get(/databases/$(database)/documents/inviteCodes/$(code));
    }

    function isPairMember(pairId) {
      return isSignedIn()
        && pairDoc(pairId).data.memberIds is list
        && request.auth.uid in pairDoc(pairId).data.memberIds;
    }

    function canJoinPendingPair(pairId) {
      return isSignedIn()
        && resource.data.status == 'pending'
        && resource.data.memberIds is list
        && resource.data.memberIds.size() == 1
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() == 2
        && request.resource.data.status == 'active'
        && request.resource.data.inviteCode == resource.data.inviteCode
        && !(request.auth.uid in resource.data.memberIds)
        && request.auth.uid in request.resource.data.memberIds
        && inviteDoc(resource.data.inviteCode).data.pairId == pairId
        && inviteDoc(resource.data.inviteCode).data.status == 'pending'
        && inviteDoc(resource.data.inviteCode).data.createdBy == resource.data.memberIds[0]
        && inviteDoc(resource.data.inviteCode).data.usedBy == null
        && inviteDoc(resource.data.inviteCode).data.expiresAt > request.time;
    }

    match /users/{userId} {
      allow read, write: if isSelf(userId);
    }

    match /pairs/{pairId} {
      allow read: if isPairMember(pairId);
      allow create: if isSignedIn()
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() == 1
        && request.resource.data.memberIds[0] == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.inviteCode is string;
      allow update: if isPairMember(pairId) || canJoinPendingPair(pairId);
      allow delete: if false;
    }

    match /pairs/{pairId}/events/{eventId} {
      allow read, create: if isPairMember(pairId);
      allow update, delete: if false;
    }

    match /pairs/{pairId}/liveSessions/{sessionId} {
      allow read, create, update: if isPairMember(pairId);
      allow delete: if false;
    }

    match /inviteCodes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.pairId is string
        && request.resource.data.status == 'pending'
        && request.resource.data.usedBy == null
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.time;
      allow update: if isSignedIn()
        && resource.data.status == 'pending'
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.pairId == resource.data.pairId
        && request.resource.data.expiresAt == resource.data.expiresAt
        && (
          (
            resource.data.createdBy == request.auth.uid
            && request.resource.data.status == 'expired'
            && request.resource.data.usedBy == null
          )
          || (
            resource.data.createdBy != request.auth.uid
            && request.resource.data.status == 'approved'
            && request.resource.data.usedBy == request.auth.uid
            && request.resource.data.expiresAt > request.time
          )
        );
      allow delete: if false;
    }

    match /devices/{deviceId} {
      allow read, write: if isSignedIn();
    }
  }
}
